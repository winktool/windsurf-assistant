# 道法自然 — 仅保留核心, 去除一切干扰

# 账号池数据 — 绝不入库
*.auth_blob
accounts.json
keypool.json
oneshot_token.json
inject_result.json
quota_snapshots.json
inuse_marks.json
instance_claims.json

# Secrets
.env
.env.local
secrets.env
*.pem
*.key

# Build artifacts
*.vsix
node_modules/

# Temp & Logs
*.log
*.bak
__pycache__/

# Development-only (local-only artifacts)
LOCAL_MAPPING.md
.vsixmanifest

# dist/ is the original Windsurf extension (4MB+), not our code
dist/

# Allow wam-bundle media (icon needed)
!wam-bundle/media/

# Monitor runtime artifacts
monitor/logs/
monitor/*.db
