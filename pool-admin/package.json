{
  "name": "pool-admin",
  "displayName": "WAM Pool Admin · 号池管理端",
  "description": "Windsurf 号池管理端 v2.0 — 无感切号·智能轮转·验证清理·有效期刷新·LAN Guard·多实例协调",
  "version": "2.0.0",
  "publisher": "dao",
  "license": "MIT",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pool-admin-container",
          "title": "号池管理",
          "icon": "dist/media/icon.svg"
        }
      ]
    },
    "views": {
      "pool-admin-container": [
        {
          "id": "poolAdmin.panel",
          "name": "无感切号 · 账号管理",
          "type": "webview"
        }
      ]
    },
    "commands": [
      { "command": "poolAdmin.openPanel", "title": "号池: 管理面板" },
      { "command": "poolAdmin.smartRotate", "title": "号池: 智能轮转" },
      { "command": "poolAdmin.refresh", "title": "号池: 刷新" },
      { "command": "poolAdmin.verifyClean", "title": "号池: 验证清理" },
      { "command": "poolAdmin.scanExpiry", "title": "号池: 刷新有效期" },
      { "command": "poolAdmin.addAccount", "title": "号池: 添加账号" },
      { "command": "poolAdmin.switchMode", "title": "号池: 切换模式 (WAM/官方)" }
    ]
  },
  "modules": {
    "extension.js": "核心入口 — 激活/命令注册/生命周期",
    "poolManager.js": "号池管理器 — 账号调度/额度查询/智能轮转/预判切换",
    "adminPanel.js": "管理面板 — WebView UI/状态展示/操作交互",
    "lanGuard.js": "LAN安全守护 — 局域网设备发现/Hub通信/多实例锁"
  }
}
